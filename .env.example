# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: pre-generated session string to skip QR login on startup
TELEGRAM_SESSION_STRING=

# YouTube Data API v3 key (from https://console.cloud.google.com)
# Enables fast search without yt-dlp. Get one free key — no billing needed.
GOOGLE_API_KEY=

# YouTube cookies (Netscape format) — fixes 403 download errors on server IPs
# Export from Chrome using "Get cookies.txt LOCALLY" extension while logged in to YouTube
YOUTUBE_COOKIES=

# Server port (Railway sets this automatically)
PORT=8080

# Bot owner username (for /qr command — no @ needed)
BOT_OWNER_USERNAMES=

# Persistent data directory (attach a Railway Volume at /data for persistence)
DATA_DIR=/data
